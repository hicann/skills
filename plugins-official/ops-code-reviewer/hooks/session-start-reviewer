#!/usr/bin/env bash
# SessionStart hook for CANNBot (ops-code-reviewer) plugin.
#
# On each session start:
#   1. Inject AGENTS.md content as session context (with absolute paths)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# --- Step 1: Build session context ---
AGENTS_MD="${PLUGIN_ROOT}/AGENTS.md"
if [ ! -f "$AGENTS_MD" ]; then
  exit 0
fi

# Read AGENTS.md, strip frontmatter
agents_content=$(sed -n '/^---$/,/^---$/!p' "$AGENTS_MD" 2>/dev/null || cat "$AGENTS_MD")

# Build path guide — tell the agent where everything actually lives
path_guide="## CANNBot Installation Paths (ops-code-reviewer)

All \`agents/\` references in this document resolve to absolute paths:
- \`agents/ascendc-ops-reviewer.md\` → \`${PLUGIN_ROOT}/agents/ascendc-ops-reviewer.md\"

Paths starting with \`ops/{operator_name}/\` or \`./ops/\` are relative to the user's current working directory."

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

path_guide_escaped=$(escape_for_json "$path_guide")
agents_escaped=$(escape_for_json "$agents_content")
session_context="<CANNBOT_CONTEXT>\nYou are CANNBot - Ascend C Code Review Team.\n\n${path_guide_escaped}\n\n${agents_escaped}\n</CANNBOT_CONTEXT>"

# Output JSON for Claude Code hook system
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF
else
  cat <<EOF
{
  "additional_context": "${session_context}"
}
EOF
fi

exit 0
