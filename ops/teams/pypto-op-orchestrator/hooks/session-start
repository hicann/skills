#!/usr/bin/env bash
# SessionStart hook for CANNBot (pypto-op-orchestrator) plugin.
#
# On each session start:
#   1. Ensure PyPTO source repository exists; clone if missing
#   2. Inject AGENTS.md content as session context (with absolute paths)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PYPTO_DIR="${PLUGIN_ROOT}/pypto"

# --- Step 1: Ensure PyPTO source repository is available ---
if [ ! -d "$PYPTO_DIR/.git" ]; then
  git clone --quiet https://gitcode.com/cann/pypto.git "$PYPTO_DIR" 2>/dev/null || true
fi

# --- Step 2: Build session context ---
AGENTS_MD="${PLUGIN_ROOT}/AGENTS.md"
if [ ! -f "$AGENTS_MD" ]; then
  exit 0
fi

# Read AGENTS.md, strip frontmatter
agents_content=$(sed -n '/^---$/,/^---$/!p' "$AGENTS_MD" 2>/dev/null || cat "$AGENTS_MD")

# Build path guide — tell the agent where everything actually lives
path_guide="## CANNBot Installation Paths (pypto-op-orchestrator)

All relative references in this document resolve to absolute paths:
- \`pypto/\` → \`${PYPTO_DIR}/\`
- \`skills/\` → \`${PLUGIN_ROOT}/skills/\`
- \`agents/\` → \`${PLUGIN_ROOT}/agents/\`

Paths starting with \`custom/{op}/\` are relative to the user's current working directory."

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

path_guide_escaped=$(escape_for_json "$path_guide")
agents_escaped=$(escape_for_json "$agents_content")
session_context="<CANNBOT_CONTEXT>\nYou are CANNBot - PyPTO Operator Development Orchestrator.\n\n${path_guide_escaped}\n\n${agents_escaped}\n</CANNBOT_CONTEXT>"

# Output JSON for Claude Code hook system
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF
else
  cat <<EOF
{
  "additional_context": "${session_context}"
}
EOF
fi

exit 0
